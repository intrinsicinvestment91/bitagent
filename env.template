# BitAgent Start9 Configuration Template
# Copy this to .env and fill in your values

# LNbits Configuration (REQUIRED)
# Get these from your LNbits instance
LNBITS_URL=https://your-lnbits-instance.com
LNBITS_API_KEY=your-lnbits-api-key-here

# Start9 Configuration (REQUIRED)
# Your Start9 node identifier
START9_NODE_ID=your-start9-node-id

# Optional: Fedimint Configuration
# Run fedimint-clientd locally and point to it here.
# Join a public federation via: fedimint-clientd join <invite-code>
# Public federations: https://fedimint.org/docs/intro (community list)
FEDIMINT_CLIENTD_URL=http://localhost:3333
FEDIMINT_CLIENTD_PASSWORD=your-fedimint-clientd-password

# Optional: Nostr Configuration
# For agent discovery and communication
NOSTR_PRIVATE_KEY=your-nostr-private-key-here

# Optional: Database Configuration
# For persistent storage (defaults to SQLite)
DATABASE_URL=sqlite:///data/bitagent.db

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Logging Configuration
LOG_LEVEL=INFO
