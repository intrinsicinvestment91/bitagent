{
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(pytest*)",
      "Bash(pip*)",
      "Bash(docker*)",
      "Bash(uvicorn*)",
      "Bash(git *)",
      "Bash(curl *)",
      "Bash(jq *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; echo \"$f\" | grep -qE '\\.py$' && python -m py_compile \"$f\" 2>&1 && echo \"syntax ok\" || true; }",
            "timeout": 15,
            "statusMessage": "Checking Python syntax..."
          }
        ]
      }
    ]
  }
}
